{
  "name": "@saltusdev/geocanvas",
  "version": "0.1.0",
  "description": "Dependency-free GeoJSON renderer for HTML canvas with interactive polygons, markers, lines, tooltips, legends, and flat or globe projections.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": "./src/index.js",
    "./dist/geocanvas.min.js": "./dist/geocanvas.min.js",
    "./package.json": "./package.json"
  },
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SaltusDev/geocanvas.git"
  },
  "homepage": "https://github.com/SaltusDev/geocanvas#readme",
  "bugs": {
    "url": "https://github.com/SaltusDev/geocanvas/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "canvas",
    "geojson",
    "maps",
    "geospatial",
    "visualization"
  ],
  "scripts": {
    "build": "node scripts/build-geocanvas.js",
    "test": "node --test"
  },
  "devDependencies": {
    "terser": "^5.46.1"
  }
}
